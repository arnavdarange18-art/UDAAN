SECRET_KEY=replace-with-a-long-random-secret
ADMIN_SECRET_KEY=replace-with-your-admin-password
FLASK_DEBUG=false

# Use one of the following database setups:
# 1. Single URL
# DATABASE_URL=mysql+pymysql://user:password@host:3306/database_name

# 2. Railway MySQL variables
# MYSQLHOST=your-host
# MYSQLPORT=3306
# MYSQLUSER=your-user
# MYSQLPASSWORD=your-password
# MYSQLDATABASE=your-database
